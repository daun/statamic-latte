{
    "name": "daun/statamic-latte",
    "description": "Use Latte templates on Statamic sites",
    "license": "MIT",
    "type": "statamic-addon",
    "keywords": [
        "statamic",
        "latte",
        "nette",
        "view"
    ],
    "authors": [
        {
            "name": "Philipp Daun",
            "email": "post@philippdaun.net",
            "homepage": "https://philippdaun.net"
        }
    ],
    "support": {
        "email": "post@philippdaun.net"
    },
    "require": {
        "php": "^8.3",
        "miko/laravel-latte": "^3.0",
        "statamic/cms": "^6.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Daun\\StatamicLatte\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "pixelfear/composer-dist-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Daun\\StatamicLatte\\ServiceProvider"
            ]
        },
        "statamic": {
            "description": "Add support for the Latte templating engine",
            "name": "Latte Template Engine"
        }
    },
    "scripts": {
        "analyse": "./vendor/bin/phpstan analyse --memory-limit=2G",
        "format": "./vendor/bin/pint",
        "lint": "./vendor/bin/pint --test",
        "test": "./vendor/bin/pest",
        "test:ci": "./vendor/bin/pest --coverage-clover coverage.xml",
        "test:coverage": "./vendor/bin/pest --coverage"
    }
}
